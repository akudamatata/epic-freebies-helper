# Epic account
# If a value contains $, \, #, or ` (e.g. some passwords), wrap it in single
# quotes so python-dotenv keeps it as a literal: EPIC_PASSWORD='abc$def'.
# This only affects local .env files; GitHub Actions Secrets are unaffected.
EPIC_EMAIL=xxxx@qq.com
EPIC_PASSWORD=mypassword

# LLM provider
# Supported values: gemini, glm
# Keep this in sync with the key you actually fill below:
# - LLM_PROVIDER=glm    -> GLM_API_KEY must be set
# - LLM_PROVIDER=gemini -> GEMINI_API_KEY must be set
LLM_PROVIDER=glm

# GLM (recommended)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# Official Gemini API (optional)
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-pro

# For AiHubMix or another Gemini-compatible relay, set GEMINI_BASE_URL explicitly.
# Example: https://aihubmix.com

# Optional model overrides
# Leave these empty to follow GLM_MODEL or GEMINI_MODEL automatically.
# Example for GLM: glm-4.6v
# Example for Gemini / AiHubMix: gemini-2.5-pro
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# Browser runtime
# Supported values: auto, camoufox, playwright
BROWSER_BACKEND=auto

# Local one-shot debugging
ENABLE_APSCHEDULER=false
